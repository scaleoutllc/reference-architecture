#!/usr/bin/env bash
# A convenience script for running terraform in parallel.
set -euo pipefail
SCRIPT_PATH="$(cd "$(dirname "$BASH_SOURCE[0]")"; pwd -P)"

flags=""
if [[ $1 =~ (apply|destroy) ]]; then
  flags="-auto-approve -parallelism=20"
fi
terraform -chdir=$2 $1 $flags 2>&1 | sed "s@^@[$2]\: @"
